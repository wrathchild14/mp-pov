# Local development defaults. For production use the commented values instead.
SITE_ADDRESS=:80
PUBLIC_URL=http://localhost
NEXTCLOUD_TRUSTED_DOMAINS=localhost
OVERWRITEPROTOCOL=http

# Production example:
# SITE_ADDRESS=example.com
# PUBLIC_URL=https://example.com
# NEXTCLOUD_TRUSTED_DOMAINS=example.com
# OVERWRITEPROTOCOL=https

MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=replace-with-a-long-random-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-long-random-password
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=replace-with-a-long-random-password

PHP_UPLOAD_LIMIT=10G
PHP_MEMORY_LIMIT=512M
